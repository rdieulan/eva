{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "types": ["vitest/globals", "node"],
    "baseUrl": "..",
    "paths": {
      "@/*": ["client/src/*"],
      "@shared/*": ["shared/*"],
      "@services/*": ["server/src/services/*"],
      "@db/*": ["server/src/db/*"],
      "@middleware/*": ["server/src/middleware/*"]
    }
  },
  "include": [
    "./**/*.ts",
    "../client/src/**/*.ts",
    "../client/src/**/*.vue",
    "../shared/**/*.ts",
    "../server/src/services/helpers/**/*.ts"
  ]
}

