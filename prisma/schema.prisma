generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// Auth & Account Linking
// ============================================

model User {
  id                          String              @id @default(cuid())
  email                       String              @unique
  password                    String
  name                        String
  playerId                    String?             @unique
  managerId                   String?             @unique
  adminId                     String?             @unique
  linkedAccountGroupId        String?
  passwordResetToken          String?             @unique
  passwordResetTokenExpiresAt DateTime?
  createdAt                   DateTime            @default(now())
  updatedAt                   DateTime            @updatedAt
  player                      Player?             @relation(fields: [playerId], references: [id], onDelete: SetNull)
  manager                     Manager?            @relation(fields: [managerId], references: [id], onDelete: SetNull)
  admin                       Admin?              @relation(fields: [adminId], references: [id], onDelete: SetNull)
  linkedAccountGroup          LinkedAccountGroup? @relation(fields: [linkedAccountGroupId], references: [id])
  sessions                    Session[]

  @@index([linkedAccountGroupId])
}

model LinkedAccountGroup {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  accounts  User[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
}

// ============================================
// Player (joueur affilié à une équipe)
// ============================================

model Player {
  id              String           @id @default(cuid())
  permissions     Json?            // Granular permissions JSON
  teamId          String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  user            User?
  team            Team?            @relation("TeamMembers", fields: [teamId], references: [id])
  ledTeam         Team?            @relation("TeamLeader")
  availabilities  Availability[]
  createdEvents   CalendarEvent[]
  gamePlanPlayers GamePlanPlayer[]
  createdInvites  TeamInvite[]

  @@index([teamId])
}

// ============================================
// Manager (gérant de salle)
// ============================================

model Manager {
  id                       String         @id @default(cuid())
  permissions              Json?          // Manager-specific permissions
  activationToken          String?        @unique
  activationTokenExpiresAt DateTime?
  createdAt                DateTime       @default(now())
  updatedAt                DateTime       @updatedAt
  user                     User?
  managedVenues            VenueManager[]
}

// ============================================
// Admin (administrateur)
// ============================================

model Admin {
  id                       String   @id @default(cuid())
  permissions              Json     // Toutes les permissions admin (superAdmin = toutes à true)
  activationToken          String?  @unique
  activationTokenExpiresAt DateTime?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
  user                     User?
}

// ============================================
// Team & Venue
// ============================================

model Team {
  id             String          @id @default(cuid())
  name           String
  logo           String?
  venueId        String?
  leaderId       String          @unique
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  venue          Venue?          @relation(fields: [venueId], references: [id])
  leader         Player          @relation("TeamLeader", fields: [leaderId], references: [id])
  members        Player[]        @relation("TeamMembers")
  balanceRules   BalanceRule[]
  gamePlans      GamePlan[]
  calendarEvents CalendarEvent[]
  invites        TeamInvite[]

  @@index([venueId])
}

model Venue {
  id        String         @id @default(cuid())
  name      String
  city      String
  address   String
  phone     String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  teams     Team[]
  managers  VenueManager[]
}

model VenueManager {
  id        String   @id @default(cuid())
  managerId String
  venueId   String
  createdAt DateTime @default(now())
  manager   Manager  @relation(fields: [managerId], references: [id], onDelete: Cascade)
  venue     Venue    @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@unique([managerId, venueId])
  @@index([managerId])
  @@index([venueId])
}

// ============================================
// Game Plans & Maps
// ============================================

model Map {
  id        String     @id
  name      String
  images    Json       @default("[]")
  template  Json
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  gamePlans GamePlan[]
}

model GamePlan {
  id          String           @id @default(cuid())
  name        String
  mapId       String
  teamId      String?
  assignments Json
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  notes       Json?
  map         Map              @relation(fields: [mapId], references: [id], onDelete: Cascade)
  team        Team?            @relation(fields: [teamId], references: [id], onDelete: Cascade)
  players     GamePlanPlayer[]

  @@index([mapId])
  @@index([teamId])
}

model GamePlanPlayer {
  id               String   @id @default(cuid())
  gamePlanId       String
  playerId         String
  assignmentIds    Int[]
  mainAssignmentId Int?
  gamePlan         GamePlan @relation(fields: [gamePlanId], references: [id], onDelete: Cascade)
  player           Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([gamePlanId, playerId])
  @@index([gamePlanId])
  @@index([playerId])
}

// ============================================
// Calendar & Availability
// ============================================

model Availability {
  id       String             @id @default(cuid())
  playerId String
  date     DateTime           @db.Date
  status   AvailabilityStatus
  player   Player             @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([playerId, date])
  @@index([date])
}

model CalendarEvent {
  id          String    @id @default(cuid())
  date        DateTime  @db.Date
  startTime   String
  endTime     String
  type        EventType
  title       String
  description String?
  teamId      String?
  createdById String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  gamePlan    Json?
  team        Team?     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  createdBy   Player    @relation(fields: [createdById], references: [id])

  @@index([date])
  @@index([teamId])
}

model TeamInvite {
  id          String   @id @default(cuid())
  teamId      String
  team        Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  code        String   @unique
  createdById String
  createdBy   Player   @relation(fields: [createdById], references: [id])
  expiresAt   DateTime
  maxUses     Int      @default(1)
  uses        Int      @default(0)
  createdAt   DateTime @default(now())

  @@index([teamId])
  @@index([code])
}

// ============================================
// Balance Rules
// ============================================

model BalanceRule {
  id          String          @id @default(cuid())
  teamId      String
  ruleKey     String
  name        String
  description String?
  severity    BalanceSeverity @default(ERROR)
  enabled     Boolean         @default(true)
  params      Json?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  team        Team            @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([teamId, ruleKey])
  @@index([teamId])
}

// ============================================
// Enums
// ============================================

enum AvailabilityStatus {
  AVAILABLE
  UNAVAILABLE
  CONDITIONAL
}

enum EventType {
  MATCH
  EVENT
}

enum BalanceSeverity {
  ERROR
  WARNING
}


